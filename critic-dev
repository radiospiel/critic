#!/bin/bash
set -eu -o pipefail

echo "Running critic in development mode" >&2

# Build the critic binary
make build

# CPU profiling is now supported via the --cpuprofile flag:
#   critic api --cpuprofile=critic.prof
# Use "go tool pprof critic.prof" to analyze the results.

if [[ "${1:-}" =~ ^(mcp|convo|httpd|test)$ ]]; then
    # Other subcommands: pass through as-is
    exec ./critic "$@"
else
    # No subcommand or unknown arg: default to tui with cpuprofile
    exec ./critic httpd "$@"
fi
