#!/bin/bash
set -eu -o pipefail

echo "Running critic in development mode" >&2

# Build the binary
make build

# Execute with CPU profiling enabled
# Use go tool pprof critic.prof to check profile
if [[ "${1:-}" =~ ^(webui|mcp|convo|api|log)$ ]]; then
    # Other subcommands: pass through as-is
    exec ./critic "$@"
else
    # No subcommand or unknown arg: default to tui with cpuprofile
    exec ./critic tui --cpuprofile=critic.prof "$@"
fi
