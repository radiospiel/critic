#!/bin/bash
set -eu -o pipefail

echo "Running critic in development mode" >&2

# Build the critic binary
make build

# TODO(bot): support a --cpuprofile=critic.prof flag, which execute
# relevant code portions (the execution of requests) with CPU profiling 
# enabled. This allows to use the "go tool pprof critic.prof" command to
# show CPU profile information.

if [[ "${1:-}" =~ ^(mcp|convo|api)$ ]]; then
    # Other subcommands: pass through as-is
    exec ./critic "$@"
else
    # No subcommand or unknown arg: default to tui with cpuprofile
    exec ./critic api "$@"
fi
